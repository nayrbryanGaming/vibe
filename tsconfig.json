{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "outDir": "./dist",
        "rootDir": "."
    },
    "include": [
        "server/**/*.ts",
        "indexer/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "mobile"
    ]
}