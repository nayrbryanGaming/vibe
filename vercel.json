{
    "version": 2,
    "builds": [
        {
            "src": "server/api.ts",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "server/api.ts" },
        { "src": "/download", "dest": "server/api.ts" },
        { "src": "/", "dest": "/public/index.html" },
        { "src": "/(.*)", "dest": "/public/$1" }
    ]
}
